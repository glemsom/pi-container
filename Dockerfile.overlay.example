# NOTE: Replace the FROM line below with your built base image tag.
# Example: FROM pi-agent:base
FROM pi-agent:base

USER root

# Common development tools
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      gpg \
      openssh-client \
      ripgrep \
    && rm -rf /var/lib/apt/lists/*

# GitHub CLI (gh)
RUN set -eux; \
    mkdir -p /etc/apt/keyrings; \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list; \
    apt-get update; \
    apt-get install -y --no-install-recommends gh; \
    rm -rf /var/lib/apt/lists/*

USER node
# Example custom config:

# Extension: Kilo Gateway
COPY --chown=node:node extensions/kilo-gateway.ts /home/node/.pi/agent/extensions/kilo-gateway.ts

# Install lean-ctx
RUN npm install -g lean-ctx-bin
RUN lean-ctx init --global
RUN pi install npm:pi-lean-ctx

# Setup non-interactive bash environment
ENV BASH_ENV="/home/node/.lean-ctx/env.sh"

WORKDIR /workspace
