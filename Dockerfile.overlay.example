# NOTE: Replace the FROM line below with your built base image tag.
# Example: FROM pi-agent:base
FROM pi-agent:base

USER root

# Install Docker CLI (static binary)
ARG DOCKER_CLI_VERSION=29.4.0
RUN set -eux; \
    docker_arch="x86_64"; \
    curl -fsSL "https://download.docker.com/linux/static/stable/${docker_arch}/docker-${DOCKER_CLI_VERSION}.tgz" -o /tmp/docker.tgz; \
    tar -xzf /tmp/docker.tgz -C /tmp; \
    install -m 0755 /tmp/docker/docker /usr/local/bin/docker; \
    rm -rf /tmp/docker /tmp/docker.tgz

# Common development tools
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      gpg \
      openssh-client \
      ripgrep \
    && rm -rf /var/lib/apt/lists/*


# GitHub CLI (gh)
RUN set -eux; \
    mkdir -p /etc/apt/keyrings; \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list; \
    apt-get update; \
    apt-get install -y --no-install-recommends gh; \
    rm -rf /var/lib/apt/lists/*

USER node
# Install Pi Context plugin
RUN pi install npm:pi-context

# Install lean-ctx
RUN curl -fsSL https://leanctx.com/install.sh | bash

# Setup leat-ctx
RUN pi install npm:pi-lean-ctx

# Install /home/node/.lean-ctx/env.sh
RUN lean-ctx init --global

# Move env file for lean-ctx
RUN mv /home/node/.lean-ctx/env.sh /home/node/lean-ctx-env.sh
ENV LEAN_CTX_LAZY_TOOLS=1
#ENV LEAN_CTX_UNIFIED=1

ENV BASH_ENV="/home/node/lean-ctxc-env.sh"

# Install Pi Context 7 extension
RUN pi install npm:@dreki-gg/pi-context7

# Extension: Kilo Gateway
COPY --chown=node:node extensions/kilo-gateway.ts /home/node/.pi/agent/extensions/kilo-gateway.ts

WORKDIR /workspace

# Example: Run with Context7 API key
# CONTEXT7_API_KEY=your-key-here ./run-pi.sh -e CONTEXT7_API_KEY="${CONTEXT7_API_KEY}"
