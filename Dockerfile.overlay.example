FROM pi-agent:base

USER root

# ============================================
# USER: Add your OS packages here
# Examples:
RUN apt-get update && apt-get install -y --no-install-recommends \
     git \
     ripgrep \
     docker.io \
     gh \
     && rm -rf /var/lib/apt/lists/*
# ============================================

# ============================================
# USER: Add your extensions here
# Copy extension files to /workspace/extensions/ (they will be installed at runtime)
# Example:
# COPY extensions/kilo-gateway.ts /workspace/extensions/kilo-gateway.ts
# ============================================

# Create directories and embedded entrypoint script

RUN mkdir -p /home/node/.pi /home/node/.local /home/node/.pi/lean-ctx
RUN chown -R node:node /home/node/.pi /home/node/.local

RUN cat > /home/node/entrypoint.sh << 'ENTRYSCRIPT'
#!/bin/bash
set -e

# ============================================
# Docker In Docker (DinD) - start dockerd
# Must run as root
# ============================================
DOCKERD_PID=""

cleanup() {
    if [ -n "$DOCKERD_PID" ] && kill -0 "$DOCKERD_PID" 2>/dev/null; then
        echo "Stopping Docker daemon..."
        kill "$DOCKERD_PID"
        wait "$DOCKERD_PID" 2>/dev/null
    fi
}
trap cleanup EXIT

echo "Starting Docker daemon (DinD)..."
dockerd &>/var/log/dockerd.log &
DOCKERD_PID=$!

echo "Waiting for Docker daemon to be ready..."
until docker info >/dev/null 2>&1; do
    sleep 1
done
echo "Docker daemon is ready."

# ============================================
# Switch to node user for everything else
# ============================================

run_as_node() {
    su - node -c "$*"
}

run_as_node_bash() {
    su - node -c "bash -c '$*'"
}

# Ensure node owns its home dirs (defensive - should already be owned)
run_as_node_bash "mkdir -p /home/node/.pi /home/node/.local /home/node/.pi/lean-ctx"

# Set npm prefix for the node user
run_as_node npm config set prefix "/home/node/.local" --global

# First-run detection: install only if marker file doesn't exist
MARKER_FILE="/home/node/.pi/.installed"
if [ ! -f "${MARKER_FILE}" ]; then
    echo "First run detected"

    echo "Installing Pi Agent..."
    run_as_node npm install -g @mariozechner/pi-coding-agent

    echo "Installing pi-context"
    run_as_node pi install npm:pi-context

    echo "Installing lean-ctx"
    run_as_node_bash "curl -fsSL https://leanctx.com/install.sh | bash"
    run_as_node pi install npm:pi-lean-ctx

    # Install Context7 extension
    run_as_node pi install npm:@dreki-gg/pi-context7

    # Create marker to prevent re-installation
    run_as_node touch "${MARKER_FILE}"

    echo "Pi Agent setup successfully."
else
    echo "Pi Agent already setup."
fi

# LeanCTX config
su node -c "lean-ctx config set excluded_commands 'make,go build'"

# ============================================
# Execute the CMD as node user
# Using 'su node' (no '-') to preserve environment variables
# passed via docker -e flags. The '-' creates a login shell
# which resets the environment, dropping dynamic variables.
# ============================================

if [ $# -eq 0 ]; then
    exec su node -c "/home/node/.local/bin/pi"
else
    exec su node -c "$*"
fi
ENTRYSCRIPT

RUN chmod +x /home/node/entrypoint.sh

# Run as root - entrypoint starts dockerd (requires root), then switches to node
ENTRYPOINT ["/home/node/entrypoint.sh"]
CMD ["/home/node/.local/bin/pi"]
