FROM pi-agent:base

USER root

# ============================================
# USER: Add your OS packages here
# Examples:
RUN apt-get update && apt-get install -y --no-install-recommends \
     git \
     ripgrep \
     docker.io \
     && rm -rf /var/lib/apt/lists/*
# ============================================

# ============================================
# USER: Add your extensions here
# Copy extension files to /workspace/extensions/ (they will be installed at runtime)
# Example:
# COPY extensions/kilo-gateway.ts /workspace/extensions/kilo-gateway.ts
# ============================================

# Create embedded entrypoint script

RUN mkdir /home/node/.pi
RUN mkdir /home/node/.local
RUN chown -R node:node /home/node/.pi
RUN chown -R node:node /home/node/.local

USER node

RUN cat > /home/node/entrypoint.sh << 'ENTRYSCRIPT'
#!/bin/bash

set -e

export PI_HOME="/home/node/.pi"
export PI_LOCAL="/home/node/.local"
export MARKER_FILE="${PI_HOME}/.installed"
export LEAN_CTX_DATA_DIR=/home/node/.pi/lean-ctx
export BASH_ENV="/home/node/.pi/lean-ctx/env.sh"

[ ! -d "$LEAN_CTX_DATA_DIR" ] && mkdir -p "$LEAN_CTX_DATA_DIR"

# Set npm prefix for the node user
npm config set prefix "${PI_LOCAL}" --global

# First-run detection: install only if marker file doesn't exist
if [ ! -f "${MARKER_FILE}" ]; then
    echo "First run detected"

    echo "Installing Pi Agent..."
    npm install -g @mariozechner/pi-coding-agent

    echo "Installing pi-context"
    pi install npm:pi-context

    echo "Installing lean-ctx"
    curl -fsSL https://leanctx.com/install.sh | bash
    pi install npm:pi-lean-ctx

    lean-ctx init --global
    #lean-ctx init --agent pi

    # Create marker to prevent re-installation
    touch "${MARKER_FILE}"
    chown node:node "${MARKER_FILE}"

    echo "Pi Agent installed successfully."
else
    echo "Pi Agent already installed. Skipping installation."
fi

# Ensure lean-ctx functions are loaded
eval "$(lean-ctx init bash)"

# Execute the CMD as node user
$*
ENTRYSCRIPT

RUN chmod +x /home/node/entrypoint.sh

# Keep running as root - entrypoint will handle user switching
ENTRYPOINT ["/home/node/entrypoint.sh"]
CMD ["/home/node/.local/bin/pi"]
