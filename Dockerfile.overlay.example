# NOTE: Replace the FROM line below with your built base image tag.
# Example: FROM pi-agent:base
FROM pi-agent:base

USER root

# Common development tools
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      gpg \
      openssh-client \
      ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Install Bun
RUN curl -fsSL https://bun.sh/install | bash \
    && ln -s /root/.bun/bin/bun /usr/local/bin/bun

# GitHub CLI (gh)
RUN set -eux; \
    mkdir -p /etc/apt/keyrings; \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list; \
    apt-get update; \
    apt-get install -y --no-install-recommends gh; \
    rm -rf /var/lib/apt/lists/*

USER node

RUN mkdir -p /home/node/.pi/agent/

# Download Pi agents.md
RUN curl -fsSL -o /home/node/.pi/agent/AGENTS.md \
    https://raw.githubusercontent.com/mksglu/context-mode/refs/heads/main/configs/pi/AGENTS.md

# Extension: Kilo Gateway
COPY --chown=node:node extensions/kilo-gateway.ts /home/node/.pi/agent/extensions/kilo-gateway.ts

# Create mcp.json for context-mode
RUN cat > /home/node/.pi/agent/mcp.json << 'EOF'
{
  "mcpServers": {
    "context-mode": {
      "command": "node",
      "args": ["/home/node/.pi/extensions/context-mode/node_modules/context-mode/start.mjs"]
    }
  }
}
EOF


# Install context mode extension
RUN pi install npm:context-mode

WORKDIR /workspace
