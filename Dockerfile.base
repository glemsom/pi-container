FROM node:24-bookworm

USER root

# Minimal runtime deps + init process
RUN apt-get update \
    && apt-get install -y --no-install-recommends bash ca-certificates curl dumb-init tar wget yq jq \
    && rm -rf /var/lib/apt/lists/*

USER node

# Set node folder
RUN npm config set prefix /home/node/.local

# Set path
ENV PATH="/home/node/.local/bin:$PATH"

WORKDIR /workspace

ENTRYPOINT ["dumb-init", "--"]
CMD ["/bin/bash"]
